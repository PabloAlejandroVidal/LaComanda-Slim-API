### Sector activo para la prueba
@tokenSector = {{token_cocinero}}
@sectorEntradaId = 1
@sectorCocinaId = 3
@sectorCandybarId = 4

### Producto usado en la demo
@prodMalbecRose = 11
@tartaDeChocolate = 20
@heladoVainilla = 21

### Datos variables del flujo
@mesaLibre = T1238
@mesaNuevaSocio = T1238
@mesaNuevaMozo = T1235
@pedidoId = E8ML9
@tiempoEstimadoMinutos = 15


### =========================================
### FLUJO DEL PEDIDO
### =========================================

### LISTAR PEDIDOS
GET {{base}}/pedidos
Authorization: Bearer {{token_mozo}}

### CREAR PEDIDO
POST {{base}}/pedidos
Authorization: Bearer {{token_mozo}}
Content-Type: application/json

{
  "nombre": "Pedro",
  "mesa": "{{mesaLibre}}",
  "detalles": [
    {
      "id": {{heladoVainilla}},
      "cantidad": 2
    }
  ]
}

### INICIAR PREPARACIÓN (ASIGNACION)
PATCH {{base}}/pedidos/{{pedidoId}}/iniciar-preparacion
Authorization: Bearer {{tokenSector}}
Content-Type: application/json

{
  "sectorId": {{sectorCandybarId}},
  "tiempoEstimadoMinutos": {{tiempoEstimadoMinutos}}
}

### TERMINAR PREPARACION (MARCAR LISTO)
PATCH {{base}}/pedidos/{{pedidoId}}/marcar-listo
Authorization: Bearer {{tokenSector}}
Content-Type: application/json

{
  "sectorId": {{sectorCandybarId}}
}

### ENTREGAR PEDIDO COMPLETO
PATCH {{base}}/pedidos/{{pedidoId}}/entregar
Authorization: Bearer {{token_mozo}}

### COBRAR PEDIDO (SIN PEDIDOS PENDIENTES)
PATCH {{base}}/pedidos/{{pedidoId}}/cobrar
Authorization: Bearer {{token_mozo}}

### CERRAR PEDIDO (DESPUES DE COBRAR)
PATCH {{base}}/pedidos/{{pedidoId}}/cerrar
Authorization: Bearer {{token_socio}}

### CANCELAR PEDIDO (ANTES DE ENTREGAR)
PATCH {{base}}/pedidos/{{pedidoId}}/cancelar
Authorization: Bearer {{token_socio}}
Content-Type: application/json

{
  "motivoCancelacion": "El cliente se retiró"
}

### COMPLETAR ENCUESTA (DESPUES DE PAGAR)
POST {{base}}/pedidos/{{pedidoId}}/encuesta
Content-Type: application/json

{
  "puntajeMesa": 8,
  "puntajeRestaurante": 9,
  "puntajeMozo": 10,
  "puntajeCocinero": 7,
  "comentario": "Lo recomendaria"
}

### ==============================
### PEDIDOS - LISTAR
### ==============================
GET {{base}}/pedidos
Authorization: Bearer {{token_socio}}

### ==============================
### PEDIDOS - VER UNO
### ==============================
GET {{base}}/pedidos/{{pedidoId}}
Authorization: Bearer {{token_socio}}

### ==============================
### PEDIDOS - VER DETALLES
### ==============================
GET {{base}}/pedidos/{{pedidoId}}/detalles
Authorization: Bearer {{token_socio}}

### ==============================
### PENDIENTES DEL SECTOR - COCINERO
### ==============================
GET {{base}}/pedidos/detalles/pendientes
Authorization: Bearer {{token_cocinero}}

### ==============================
### EN PREPARACIÓN DEL SECTOR - COCINERO
### ==============================
GET {{base}}/pedidos/detalles/en-preparacion
Authorization: Bearer {{token_cocinero}}

### ==============================
### PENDIENTES DEL SECTOR - BARTENDER
### ==============================
GET {{base}}/pedidos/detalles/pendientes
Authorization: Bearer {{token_bartender}}

### ==============================
### EN PREPARACIÓN DEL SECTOR - BARTENDER
### ==============================
GET {{base}}/pedidos/detalles/en-preparacion
Authorization: Bearer {{token_bartender}}

### ==============================
### PENDIENTES DEL SECTOR - CERVECERO
### ==============================
GET {{base}}/pedidos/detalles/pendientes
Authorization: Bearer {{token_cervecero}}

### ==============================
### EN PREPARACIÓN DEL SECTOR - CERVECERO
### ==============================
GET {{base}}/pedidos/detalles/en-preparacion
Authorization: Bearer {{token_cervecero}}